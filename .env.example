# =============================================================
# JpMonitor - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git!
# =============================================================

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8080/api

# --- Backend Database ---
DB_HOST=jpmonitor-postgres
DB_PORT=5432
DB_NAME=jpmonitor_db
DB_USER=jpmonitor_user
DB_PASSWORD=CHANGE_ME_secure_password_here

# --- JWT Authentication ---
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_-base64_32

# --- Application ---
# Override default admin password on first run (optional)
ADMIN_PASSWORD=

# --- CORS ---
# Comma-separated list of allowed origins
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
